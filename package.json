{
  "name": "panel-for-word",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "copy-dict": "node -e \"const fs=require('fs');fs.cpSync('node_modules/kuromoji/dict','public/dict',{recursive:true,force:true})\"",
    "prepare": "npm run copy-dict",
    "predev": "npm run copy-dict",
    "prebuild": "npm run copy-dict",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fluentui/react-components": "^9.57.0",
    "@fluentui/react-icons": "^2.0.250",
    "kuromoji": "^0.1.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/kuromoji": "^0.1.3",
    "@types/office-js": "^1.0.488",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-basic-ssl": "^1.1.0",
    "@vitejs/plugin-react": "^4.3.3",
    "office-addin-dev-certs": "^2.0.6",
    "typescript": "^5.6.3",
    "vite": "^5.4.14"
  }
}
